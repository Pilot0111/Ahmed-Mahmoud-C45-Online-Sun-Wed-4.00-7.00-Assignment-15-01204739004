{
  "name": "Social-Media-API",
  "version": "1.0.0",
  "description": "Full stack social media application API built with Node.js, Express, and MongoDB. This API provides endpoints for user authentication, profile management, post creation, commenting, and liking functionality. It also includes features such as email verification, password reset, and rate limiting to enhance security and user experience.",
  "main": "dist/index.js",
  "scripts": {
    "start:dev": "cross-env NODE_ENV=development concurrently \"tsc -w\" \"node --watch dist/index.js\" ",
    "start:prod": "cross-env NODE_ENV=production concurrently \"tsc -w\" \"node --watch dist/index.js\" ",
    "build": "tsc"
  },
  "keywords": [],
  "author": "Ahmed Mahmoud",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/dotenv": "^6.1.1",
    "@types/express": "^5.0.6",
    "@types/express-rate-limit": "^5.1.3",
    "@types/helmet": "^0.0.48",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.2",
    "@types/nodemailer": "^8.0.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "google-auth-library": "^10.6.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "latest": "^0.2.0",
    "mongoose": "^9.5.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.5",
    "redis": "^5.12.1",
    "zod": "^4.3.6"
  }
}
