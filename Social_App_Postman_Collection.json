{
	"info": {
		"_postman_id": "saraha-app-auth-collection",
		"name": "Saraha App Assignment 15",
		"description": "Postman collection for testing Signup, Login, Gmail Login, Redis OTP flows, and Token Revocation.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Signup",
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"userName\": \"Ahmed Mahmoud\",\n    \"email\": \"ahmed@example.com\",\n    \"password\": \"Password123\",\n    \"cPassword\": \"Password123\",\n    \"age\": 25,\n    \"phone\": \"0123456789\",\n    \"address\": \"Cairo, Egypt\",\n    \"gender\": \"male\",\n    \"role\": \"User\"\n}",
					"options": { "raw": { "language": "json" } }
				},
				"url": { "raw": "{{baseUrl}}/auth/signup", "host": ["{{baseUrl}}"], "path": ["auth", "signup"] }
			}
		},
		{
			"name": "2. Confirm Email",
			"request": {
				"method": "PATCH",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"email\": \"ahmed@example.com\",\n    \"code\": \"123456\"\n}",
					"options": { "raw": { "language": "json" } }
				},
				"url": { "raw": "{{baseUrl}}/auth/confirm-email", "host": ["{{baseUrl}}"], "path": ["auth", "confirm-email"] }
			}
		},
		{
			"name": "3. Login",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": ["var jsonData = pm.response.json();", "if (jsonData.token) {", "    pm.collectionVariables.set(\"accessToken\", jsonData.token);", "}"],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"email\": \"ahmed@example.com\",\n    \"password\": \"Password123\"\n}",
					"options": { "raw": { "language": "json" } }
				},
				"url": { "raw": "{{baseUrl}}/auth/signin", "host": ["{{baseUrl}}"], "path": ["auth", "signin"] }
			}
		},
		{
			"name": "4. Gmail Login",
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"idToken\": \"YOUR_GOOGLE_ID_TOKEN_HERE\"\n}",
					"options": { "raw": { "language": "json" } }
				},
				"url": { "raw": "{{baseUrl}}/auth/gmail-login", "host": ["{{baseUrl}}"], "path": ["auth", "gmail-login"] }
			}
		},
		{
			"name": "5. Forget Password Request",
			"request": {
				"method": "PATCH",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"email\": \"ahmed@example.com\"\n}",
					"options": { "raw": { "language": "json" } }
				},
				"url": { "raw": "{{baseUrl}}/auth/forget-password", "host": ["{{baseUrl}}"], "path": ["auth", "forget-password"] }
			}
		},
		{
			"name": "6. Reset Password",
			"request": {
				"method": "PATCH",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"email\": \"ahmed@example.com\",\n    \"code\": \"123456\",\n    \"newPassword\": \"NewPassword123\"\n}",
					"options": { "raw": { "language": "json" } }
				},
				"url": { "raw": "{{baseUrl}}/auth/reset-password", "host": ["{{baseUrl}}"], "path": ["auth", "reset-password"] }
			}
		},
		{
			"name": "7. Update Password",
			"request": {
				"method": "PATCH",
				"header": [
					{ "key": "Authorization", "value": "{{tokenPrefix}} {{accessToken}}", "type": "text" }
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"oldPassword\": \"Password123\",\n    \"newPassword\": \"VerySecret123\",\n    \"cPassword\": \"VerySecret123\"\n}",
					"options": { "raw": { "language": "json" } }
				},
				"url": { "raw": "{{baseUrl}}/auth/update-password", "host": ["{{baseUrl}}"], "path": ["auth", "update-password"] }
			}
		},
		{
			"name": "8. Logout",
			"request": {
				"method": "POST",
				"header": [
					{ "key": "Authorization", "value": "{{tokenPrefix}} {{accessToken}}", "type": "text" }
				],
				"url": { "raw": "{{baseUrl}}/auth/logout", "host": ["{{baseUrl}}"], "path": ["auth", "logout"] }
			}
		}
	],
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:3000",
			"type": "string"
		},
		{
			"key": "accessToken",
			"value": "",
			"type": "string"
		},
		{
			"key": "tokenPrefix",
			"value": "Bearer",
			"type": "string"
		}
	]
}